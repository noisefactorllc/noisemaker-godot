# Expand a 1-based palette index into classicNoisedeck uniforms, or null if out of range (incl <=0).
static func expand_palette(index):
	if index <= 0 or index > PALETTES.size():
		return null
	var e = PALETTES[index - 1]
	return {
		"paletteOffset": e[2].duplicate(),
		"paletteAmp": e[0].duplicate(),
		"paletteFreq": e[1].duplicate(),
		"palettePhase": e[3].duplicate(),
		"paletteMode": e[4],
	}
